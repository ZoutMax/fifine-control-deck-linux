#!/bin/bash
# Classic-snap launch wrapper for PyQt6.
#
# Under classic confinement there is no gnome extension to set up the desktop
# runtime, so we point Qt at the bundled Qt6 (shipped inside the PyQt6 wheel)
# and add the staged libraries to the loader path ourselves. Arch-agnostic.
set -e

# Stash the host's own values BEFORE overwriting them below. A key that
# launches an app must hand that app the environment it would have had from a
# terminal, not ours: a host python3 inheriting our PYTHONHOME dies looking for
# its stdlib in $SNAP/usr — the same failure this file's PYTHONHOME comment
# describes for our own interpreter. actions.child_env() restores these for
# every program we exec. Only variables the host actually set are stashed, so
# "unset" survives the round trip as unset rather than as empty.
for _v in PYTHONHOME PYTHONPATH PYTHONDONTWRITEBYTECODE LD_LIBRARY_PATH LD_PRELOAD QT_PLUGIN_PATH QT_QPA_PLATFORM_PLUGIN_PATH; do
    if [ -n "${!_v+x}" ]; then export "FIFINE_HOST_${_v}=${!_v}"; fi
done
unset _v

# Bundled Python site-packages (core24 -> python3.12; glob to be version-proof).
SITE="$(ls -d "$SNAP"/lib/python3*/site-packages 2>/dev/null | head -n1)"
QT6="$SITE/PyQt6/Qt6"
LIBGNU="$(ls -d "$SNAP"/usr/lib/*-linux-gnu 2>/dev/null | head -n1)"

export PYTHONPATH="$SNAP/lib/fifine-control-deck${SITE:+:$SITE}${PYTHONPATH:+:$PYTHONPATH}"

if [ -d "$QT6" ]; then
  export QT_PLUGIN_PATH="$QT6/plugins"
  export QT_QPA_PLATFORM_PLUGIN_PATH="$QT6/plugins/platforms"
  QTLIB="$QT6/lib"
fi

export LD_LIBRARY_PATH="${QTLIB:+$QTLIB:}${LIBGNU:+$LIBGNU:}$SNAP/usr/lib${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"

# Use host fonts; classic snaps run with the real HOME for the fontconfig cache.
export FONTCONFIG_FILE="${FONTCONFIG_FILE:-/etc/fonts/fonts.conf}"

# No system-tray host assumption inside the snap.
export FIFINE_TRAY="${FIFINE_TRAY:-0}"

# Pin the bundled stdlib prefix. The python plugin's venv relocation is
# non-deterministic — if pyvenv.cfg's `home` ends up pointing at the build
# host's /usr, the interpreter looks for its stdlib in the runtime host's
# /usr/lib/python3.12 (which may not exist) and dies with "No module named
# 'encodings'". PYTHONHOME forces it to the stdlib we bundle at $SNAP/usr.
export PYTHONHOME="$SNAP/usr"

# Run the bundled interpreter directly (the venv symlink points at it anyway).
PY="$SNAP/usr/bin/python3.12"
[ -x "$PY" ] || PY="$SNAP/bin/python3"
[ -x "$PY" ] || PY="python3"
exec "$PY" -m fifine_deck "$@"
